# Copy to .env and fill in. Do not commit .env.

# LLM (example: Gemini via LiteLLM-style string in MODEL)
MODEL=gemini/gemini-2.0-flash
GEMINI_API_KEY=

# Optional alias read by google-vertex embedder config
GOOGLE_API_KEY=

SERPER_API_KEY=

# Embeddings (chief_editor knowledge / crew memory)
# Crew embedder uses provider google-vertex + model gemini-embedding-001 via google-genai SDK
EMBEDDINGS_GOOGLE_GENERATIVE_AI_TASK_TYPE=RETRIEVAL_DOCUMENT

# Windows: reduce native crash risk with threaded BLAS/ONNX (see WINDOWS_ENV.md)
OMP_NUM_THREADS=1
MKL_NUM_THREADS=1
OPENBLAS_NUM_THREADS=1
TOKENIZERS_PARALLELISM=false
